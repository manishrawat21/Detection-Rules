EventID=1 Image IN ("*\\powershell.exe", "*\\pwsh.exe") CommandLine IN ("*-encoded*", "*-enc*", "*-e *", "*-EncodedCommand*", "*-en*", "*-enco*") OR (ParentImage IN ("*\\winword.exe", "*\\excel.exe", "*\\outlook.exe", "*\\wscript.exe", "*\\mshta.exe", "*\\cmd.exe", "*\\control.exe", "*\\powershell.exe") CommandLine IN ("*wget*", "*curl*", "*Invoke-WebRequest*", "*Net.WebClient*", "*DownloadString*", "*DownloadFile*", "*Start-Process*")) OR (ParentImage IN ("*\\winword.exe", "*\\excel.exe", "*\\outlook.exe", "*\\wscript.exe", "*\\mshta.exe", "*\\cmd.exe", "*\\control.exe", "*\\powershell.exe") CommandLine IN ("*-NoLogo*", "*-NoProfile*", "*-nopi*", "*-nop*", "*-noexit*", "*-ep bypass*", "*-window hidden*"))
